  <property name="styleSheet">
   <string notr="true">/* GENEL PENCERE */
QWidget {
    background: transparent; /* Her şeyin arkasını boşaltır */
    color: white;
}

/* GRUP KUTULARI (Cam Efekti) */
QGroupBox {
    background-color: rgba(20, 20, 20, 80); /* Şeffaflığı artırdık (80/255) */
    border: 1px solid rgba(255, 255, 255, 40); /* İnce beyaz cam sınırı */
    border-radius: 15px;
    margin-top: 20px;
    padding: 10px;
}

/* BUTONLAR (Neon ve Şeffaf) */
QPushButton {
    background-color: rgba(0, 170, 255, 150); /* Yarı şeffaf mavi */
    border: 1px solid #00AAFF;
    border-radius: 8px;
    color: white;
    font-weight: bold;
    min-height: 30px;
}

QPushButton:hover {
    background-color: rgba(0, 170, 255, 200); /* Üstüne gelince belirginleşir */
}

/* GİRİŞ ALANLARI */
QLineEdit, QComboBox, QSpinBox {
    background-color: rgba(255, 255, 255, 30);
    border: 1px solid rgba(255, 255, 255, 50);
    border-radius: 5px;
    color: white;
}

/* TABLO */
QTableWidget {
    background-color: rgba(0, 0, 0, 60);
    gridline-color: rgba(255, 255, 255, 20);
    border: none;
}</string>
