  <property name="styleSheet">
   <string notr="true">QFrame, QGroupBox {
    background-color: rgba(20, 24, 35, 150); /* Yarı şeffaf koyu lacivert */
    border: 1px solid rgba(255, 255, 255, 15);
    border-radius: 15px;
    margin-top: 10px;
}

/* Başlık Yazıları */
QLabel {
    color: #E0E6ED;
    font-weight: 600;
    background: transparent;
}

/* Modern Input Alanları */
QLineEdit, QDateTimeEdit, QComboBox {
    background-color: rgba(0, 0, 0, 100);
    border: 1px solid rgba(79, 209, 197, 50); /* Hafif turkuaz kenarlık */
    border-radius: 8px;
    padding: 8px;
    color: white;
}

QLineEdit:focus {
    border: 1px solid #4FD1C5;
    background-color: rgba(0, 0, 0, 150);
}

/* Tablo Tasarımı (Transparan ve Temiz) */
QTableWidget {
    background-color: transparent;
    alternate-background-color: rgba(255, 255, 255, 5);
    border: none;
    gridline-color: rgba(255, 255, 255, 10);
}

QHeaderView::section {
    background-color: rgba(30, 41, 59, 180);
    color: #4FD1C5;
    padding: 10px;
    border: none;
    font-weight: bold;
    text-transform: uppercase;
    font-size: 11px;
}

/* Ana Aksiyon Butonu (Ödeme Al) */
QPushButton#btn_odeme_al {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #4FD1C5, stop:1 #2C7A7B);
    color: #0F172A;
    font-weight: bold;
    border-radius: 10px;
    padding: 12px;
}

QPushButton#btn_odeme_al:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #64FFDA, stop:1 #4FD1C5);
}

/* İkincil Buton (Ara) */
QPushButton#btn_ara {
    background-color: rgba(79, 209, 197, 30);
    border: 1px solid #4FD1C5;
    color: #4FD1C5;
    border-radius: 8px;
}

QPushButton#btn_ara:hover {
    background-color: #4FD1C5;
    color: #0F172A;
}

/* Scrollbar (Zarif ve İnce) */
QScrollBar:vertical {
    border: none;
    background: transparent;
    width: 5px;
}

QScrollBar::handle:vertical {
    background: rgba(79, 209, 197, 80);
    border-radius: 2px;
}
QTableWidget QTableCornerButton::section {
    background-color: transparent;
    border: none;
}
QGroupBox {
    background-color: transparent; /* İçindeki siyahlığı tamamen kaldırır */
    border: 1px solid rgba(255, 255, 255, 30); /* İnce beyazımsı bir çerçeve */
    border-radius: 15px;
    margin-top: 20px; /* Başlık yazısının yerleşmesi için */
    padding: 10px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 10px;
    color: #4FD1C5; /* Başlık rengi (Turkuaz) */
    font-weight: bold;
}
/* İstatistik Kartları için Özel Panel */
QFrame#istatistik_kart {
    background-color: rgba(30, 41, 59, 120); /* Hafif lacivert cam efekti */
    border: 1px solid rgba(79, 209, 197, 60); /* Turkuaz parlayan kenarlık */
    border-radius: 15px;
}

/* Kart İçindeki Başlık (Örn: Toplam Üye Sayısı) */
QLabel#label{
    color: #94A3B8; /* Daha sönük gri/mavi tonu */
    font-size: 12px;
    font-weight: bold;
    text-transform: uppercase;
}

/* Kart İçindeki Veri (Örn: 150) */
QLabel#label_toplam_uye{
    color: #4FD1C5; /* Parlak Turkuaz */
    font-size: 24px;
    font-weight: 800;
}</string>
